# Токен Telegram бота
# Получить можно у @BotFather в Telegram
TELEGRAM_BOT_TOKEN=your_bot_token_here

# ID чата, в котором бот будет работать
# Чтобы узнать ID чата:
# 1. Добавьте бота @userinfobot в ваш групповой чат
# 2. Бот отправит информацию о чате, включая его ID
# 3. ID чата обычно отрицательное число, например: -1001234567890
ALLOWED_CHAT_ID=-1001234567890

# Настройки PostgreSQL
POSTGRES_USER=gymbot
POSTGRES_PASSWORD=changeme_strong_password
POSTGRES_DB=gymbot

# Настройки pgAdmin (веб-интерфейс для базы данных)
# Доступен по адресу: http://localhost:5050
PGADMIN_EMAIL=admin@example.com
PGADMIN_PASSWORD=changeme_pgadmin_password

# DATABASE_URL автоматически формируется в docker-compose.yml
# Если запускаете локально без Docker, раскомментируйте и настройте:
# DATABASE_URL=postgresql://gymbot:changeme_strong_password@localhost:5432/gymbot?sslmode=disable